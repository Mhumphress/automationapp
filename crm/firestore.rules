rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isApprovedUser() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isApprovedUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner() {
      return resource.data.createdBy == request.auth.uid;
    }

    // ── Tenant helper functions ──────────────
    function isTenantMember(tenantId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid));
    }

    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)).data.role in ['admin', 'owner'];
    }

    function isTenantOwner(tenantId) {
      return isTenantMember(tenantId) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)).data.role == 'owner';
    }

    function tenantIsActive(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)).data.status == 'active';
    }

    // Check if user has a valid user_tenants mapping for this tenant
    function hasValidTenantMapping(tenantId) {
      return isAuth()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/user_tenants/$(request.auth.token.email))
        && get(/databases/$(database)/documents/user_tenants/$(request.auth.token.email)).data.tenantId == tenantId;
    }

    // ── Users (CRM access) ────────────────────
    // Only admins can create CRM user docs. No self-registration.
    // This prevents portal users from gaining CRM access.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isApprovedUser();
      allow create: if isAdmin();
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }

    // ── CRM Data Collections ─────────────────
    match /contacts/{contactId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }
    }

    match /companies/{companyId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());
    }

    match /deals/{dealId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }
    }

    match /tasks/{taskId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }
    }

    match /invoices/{invoiceId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }
    }

    match /subscriptions/{subId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }

      match /payments/{paymentId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update: if isApprovedUser();
        allow delete: if isAdmin();
      }
    }

    match /internal_subs/{id} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());
    }

    match /notes/{noteId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());
    }

    match /payments/{paymentId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());
    }

    // ── Activity (collection group for CRM audit log — admin only) ──
    match /{path=**}/activity/{activityId} {
      allow read: if isAdmin();
    }

    // ── Settings ─────────────────────────────
    match /settings/{settingId} {
      allow read: if isApprovedUser();
      allow write: if isAdmin();
    }

    // ── User-Tenant Mapping ───────────────────
    // Portal users can only read their OWN mapping (by email).
    match /user_tenants/{emailKey} {
      allow read: if isAuth() && request.auth.token.email != null
                  && emailKey == request.auth.token.email;
      allow write: if isAdmin();
    }

    // ── Product Catalog (readable by any authenticated user) ──
    match /packages/{packageId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /addons/{addonId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /features/{featureId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /verticals/{verticalId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Tenants ─────────────────────────────
    match /tenants/{tenantId} {
      // Only admins and verified tenant members can read
      allow read: if isAdmin() || isTenantMember(tenantId);
      allow create: if isAdmin();
      // Only admins can update tenant doc (billing, status, package)
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // Tenant users
      match /users/{userId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        // Self-registration: user can create their OWN doc IF they have
        // a valid user_tenants mapping for THIS tenant, and the role
        // matches what was provisioned in the mapping.
        allow create: if isAdmin()
          || (isTenantAdmin(tenantId) && tenantIsActive(tenantId))
          || (isAuth() && userId == request.auth.uid
              && hasValidTenantMapping(tenantId)
              && request.resource.data.role == get(/databases/$(database)/documents/user_tenants/$(request.auth.token.email)).data.role);
        allow update: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantOwner(tenantId) && tenantIsActive(tenantId));
      }

      // Invitations — gated by tenantIsActive
      match /invitations/{inviteId} {
        allow read: if isAdmin() || isTenantAdmin(tenantId);
        allow create: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
        allow update: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      // Tenant billing — admin only
      match /invoices/{invoiceId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /payments/{paymentId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // Activity — members can read and create, never edit/delete
      match /activity/{activityId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow update, delete: if false;
      }

      match /notifications/{notifId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      // Settings — admin/tenant-admin can write, gated by active status
      match /settings/{settingId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow write: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      // ── Tenant CRM data — all gated by membership + active status ──

      match /contacts/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /invoices_crm/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /tasks/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /scheduling/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /inventory/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /tickets/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /jobs/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /quotes/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /work_orders/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /bom/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /projects/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /properties/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /leases/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /maintenance/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /appointments/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /services_menu/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /loyalty/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /time_entries/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /proposals/{docId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }
    }
  }
}
