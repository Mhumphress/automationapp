rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isApprovedUser() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isApprovedUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner() {
      return resource.data.createdBy == request.auth.uid;
    }

    // ── Tenant helper functions ──────────────
    function isTenantMember(tenantId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid));
    }

    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)).data.role in ['admin', 'owner'];
    }

    function isTenantOwner(tenantId) {
      return isTenantMember(tenantId) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)).data.role == 'owner';
    }

    function tenantIsActive(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)).data.status == 'active';
    }

    // Access = active OR past_due (grace period, read-only).
    // Anything else (suspended, cancelled, unknown) → no access.
    // This gates READS on tenant data so a suspended tenant cannot bypass
    // the UI and read data directly from the Firestore SDK.
    function tenantHasAccess(tenantId) {
      let status = get(/databases/$(database)/documents/tenants/$(tenantId)).data.status;
      return status == 'active' || status == 'past_due';
    }

    // Check if user has a valid user_tenants mapping for this tenant
    function hasValidTenantMapping(tenantId) {
      return isAuth()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/user_tenants/$(request.auth.token.email))
        && get(/databases/$(database)/documents/user_tenants/$(request.auth.token.email)).data.tenantId == tenantId;
    }

    // ── Users (CRM access) ────────────────────
    // Only admins can create CRM user docs. No self-registration.
    // This prevents portal users from gaining CRM access.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isApprovedUser();
      allow create: if isAdmin();
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }

    // ── CRM Data Collections ─────────────────
    match /contacts/{contactId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }

      // Customer-level files (metadata docs — Storage paths referenced)
      match /files/{fileId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update: if isApprovedUser();
        allow delete: if isApprovedUser();
      }
    }

    // ── Subscription events (append-only queryable history) ──
    match /subscription_events/{eventId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update, delete: if false;
    }

    // ── Quotes ───────────────────────────────
    match /quotes/{quoteId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin();
    }

    // ── Public quote views (public read, admin write) ──
    match /quote_views/{token} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Public quote responses (anonymous create, admin read) ──
    match /quote_responses/{token} {
      // Customers can create their response if the document ID matches the token field.
      // Prevents reuse of the same response doc and blocks reads by non-admins.
      allow create: if request.resource.data.token == token
                    && request.resource.data.response in ['accepted', 'declined']
                    && request.resource.data.response.size() <= 16;
      allow read, update, delete: if isAdmin();
    }

    match /companies/{companyId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());
    }

    match /deals/{dealId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }
    }

    match /tasks/{taskId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }
    }

    match /invoices/{invoiceId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }
    }

    match /subscriptions/{subId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());

      match /activity/{activityId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update, delete: if false;
      }

      match /payments/{paymentId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser();
        allow update: if isApprovedUser();
        allow delete: if isAdmin();
      }
    }

    match /internal_subs/{id} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());
    }

    match /notes/{noteId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());
    }

    match /payments/{paymentId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isAdmin() || (isApprovedUser() && isOwner());
    }

    // ── Messaging: threaded conversations between operator and tenants ──
    //
    // message_threads is a root collection so operators can query across all
    // tenants, while each thread carries a `tenantId` that restricts access
    // to members of that tenant.

    match /message_threads/{threadId} {
      allow read: if isApprovedUser()
        || (isAuth() && isTenantMember(resource.data.tenantId));
      allow create: if isApprovedUser()
        || (isAuth()
            && request.resource.data.tenantId is string
            && isTenantMember(request.resource.data.tenantId)
            && tenantHasAccess(request.resource.data.tenantId));
      // Both sides can update to flip unread flags / bump lastMessage metadata.
      allow update: if isApprovedUser()
        || (isAuth() && isTenantMember(resource.data.tenantId));
      allow delete: if isApprovedUser();

      match /messages/{messageId} {
        allow read: if isApprovedUser()
          || (isAuth() && isTenantMember(
                get(/databases/$(database)/documents/message_threads/$(threadId)).data.tenantId
              ));
        // Tenant users can only create messages with sender === 'tenant'.
        // Operators (isApprovedUser) can create either sender.
        allow create: if isApprovedUser()
          || (isAuth()
              && isTenantMember(
                   get(/databases/$(database)/documents/message_threads/$(threadId)).data.tenantId
                 )
              && tenantHasAccess(
                   get(/databases/$(database)/documents/message_threads/$(threadId)).data.tenantId
                 )
              && request.resource.data.sender == 'tenant');
        // Messages are immutable once written (for audit integrity).
        allow update, delete: if isApprovedUser();
      }
    }

    // ── Activity (collection group for CRM audit log — admin only) ──
    match /{path=**}/activity/{activityId} {
      allow read: if isAdmin();
    }

    // ── Root-level counters (admin-only) ─────
    match /counters/{counterId} {
      allow read, write: if isAdmin();
    }

    // ── Settings ─────────────────────────────
    // The branding doc is public-readable so the anonymous /quote.html page
    // can fetch your business name + logo. Everything else in /settings stays
    // behind auth.
    match /settings/{settingId} {
      allow read: if settingId == 'branding' || isApprovedUser();
      allow write: if isAdmin();
    }

    // ── User-Tenant Mapping ───────────────────
    // Portal users can only read their OWN mapping (by email). CRM admins can
    // list all mappings (needed for wipe + support operations).
    // Tenant admins can invite users to their own tenant (create/update/delete
    // mapping where tenantId points at their tenant).
    match /user_tenants/{emailKey} {
      allow read: if isAdmin()
                  || (isAuth() && request.auth.token.email != null
                      && emailKey == request.auth.token.email);
      allow create: if isAdmin()
                    || (isAuth() && request.resource.data.tenantId is string
                        && isTenantAdmin(request.resource.data.tenantId));
      allow update, delete: if isAdmin()
                            || (isAuth() && resource.data.tenantId is string
                                && isTenantAdmin(resource.data.tenantId));
    }

    // ── Product Catalog (readable by any authenticated user) ──
    match /packages/{packageId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /addons/{addonId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /features/{featureId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /verticals/{verticalId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Tenants ─────────────────────────────
    match /tenants/{tenantId} {
      // Only admins and verified tenant members can read
      allow read: if isAdmin() || isTenantMember(tenantId);
      allow create: if isAdmin();
      // Only admins can update tenant doc (billing, status, package)
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // Tenant users
      match /users/{userId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        // Self-registration: user can create their OWN doc IF they have
        // a valid user_tenants mapping for THIS tenant, and the role
        // matches what was provisioned in the mapping.
        allow create: if isAdmin()
          || (isTenantAdmin(tenantId) && tenantIsActive(tenantId))
          || (isAuth() && userId == request.auth.uid
              && hasValidTenantMapping(tenantId)
              && request.resource.data.role == get(/databases/$(database)/documents/user_tenants/$(request.auth.token.email)).data.role);
        allow update: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantOwner(tenantId) && tenantIsActive(tenantId));
      }

      // Invitations — gated by tenantIsActive
      match /invitations/{inviteId} {
        allow read: if isAdmin() || (isTenantAdmin(tenantId) && tenantHasAccess(tenantId));
        allow create: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
        allow update: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      // Tenant billing — admin + tenant admins (for self-service seat invoices).
      match /invoices/{invoiceId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create: if isAdmin() || isTenantAdmin(tenantId);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /payments/{paymentId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // Activity — members can read and create, never edit/delete
      match /activity/{activityId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow update, delete: if false;
      }

      match /notifications/{notifId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      // Settings — admin/tenant-admin can write, gated by active status
      match /settings/{settingId} {
        allow read: if isAdmin() || isTenantMember(tenantId);
        allow write: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      // ── Tenant CRM data — all gated by membership + active status ──

      match /contacts/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /invoices_crm/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /tasks/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /scheduling/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /inventory/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /tickets/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /jobs/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /quotes/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /work_orders/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /bom/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /projects/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /properties/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /leases/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /maintenance/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /appointments/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /services_menu/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /loyalty/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /time_entries/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      match /proposals/{docId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      // Recurring + one-off charges (rent, insurance, memberships, retainers,
      // late fees, policy violations, etc). Sweep generates invoices_crm docs
      // from these automatically.
      match /recurring_charges/{chargeId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      // Tenant-level files — metadata for uploaded documents. Storage path
      // referenced from inside the doc.
      match /files/{fileId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow create, update: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
        allow delete: if isAdmin() || (isTenantAdmin(tenantId) && tenantIsActive(tenantId));
      }

      // Counters — per-tenant auto-increment docs (e.g., ticket numbers).
      // Reads + writes inside runTransaction must be permitted for active tenant members.
      match /counters/{counterId} {
        allow read: if isAdmin() || (isTenantMember(tenantId) && tenantHasAccess(tenantId));
        allow write: if isAdmin() || (isTenantMember(tenantId) && tenantIsActive(tenantId));
      }
    }
  }
}
