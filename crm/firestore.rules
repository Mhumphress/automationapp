rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /contacts/{contactId} {
      allow read, write: if isAuth();
    }

    match /companies/{companyId} {
      allow read, write: if isAuth();
    }

    match /contacts/{contactId}/activity/{activityId} {
      allow read, write: if isAuth();
    }

    match /deals/{dealId}/activity/{activityId} {
      allow read, write: if isAuth();
    }

    match /tasks/{taskId}/activity/{activityId} {
      allow read, write: if isAuth();
    }

    match /invoices/{invoiceId}/activity/{activityId} {
      allow read, write: if isAuth();
    }

    match /subscriptions/{subId}/activity/{activityId} {
      allow read, write: if isAuth();
    }

    match /subscriptions/{subId}/payments/{paymentId} {
      allow read, write: if isAuth();
    }

    match /internal_subs/{id} {
      allow read, write: if isAuth();
    }

    match /deals/{dealId} {
      allow read, write: if isAuth();
    }

    match /tasks/{taskId} {
      allow read, write: if isAuth();
    }

    match /notes/{noteId} {
      allow read, write: if isAuth();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isAuth();
    }

    match /payments/{paymentId} {
      allow read, write: if isAuth();
    }

    match /subscriptions/{subId} {
      allow read, write: if isAuth();
    }

    match /messages/{messageId} {
      allow read, write: if isAuth();
    }

    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
